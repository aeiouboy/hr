        <mxCell id="e-start-review" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="start" target="review" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Review → Decision -->
        <mxCell id="e-review-dec" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="review" target="decision" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision → Pass (top exit, route up then right) -->
        <mxCell id="e-dec-pass" value="Pass" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#28a745;strokeWidth=2;html=1;fontSize=10;fontColor=#28a745;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="decision" target="pass-action" parent="lane-hradmin">
