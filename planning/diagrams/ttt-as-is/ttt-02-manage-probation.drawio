          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Transfer → End -->
        <mxCell id="e-transfer-end" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#dc3545;strokeWidth=2;html=1;" edge="1" source="fail-transfer" target="fail-end" parent="lane-hradmin">
