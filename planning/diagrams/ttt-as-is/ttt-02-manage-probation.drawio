            <Array as="points">
              <mxPoint x="520" y="150" />
              <mxPoint x="660" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Decision → Extend (right exit, horizontal) -->
        <mxCell id="e-dec-extend" value="Extend" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#e6a817;strokeWidth=2;html=1;fontSize=10;fontColor=#e6a817;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="decision" target="extend-action" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="620" y="595" />
              <mxPoint x="620" y="440" />
              <mxPoint x="660" y="440" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Decision → Fail (bottom exit, route down then right) -->
        <mxCell id="e-dec-fail" value="Fail" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#dc3545;strokeWidth=2;html=1;fontSize=10;fontColor=#dc3545;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="decision" target="fail-terminate" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="755" />
              <mxPoint x="660" y="755" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Pass branch edges -->
        <mxCell id="e-pass-verify" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="pass-action" target="pass-verify" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-pass-end" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#28a745;strokeWidth=2;html=1;" edge="1" source="pass-verify" target="pass-end" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Extend branch edges -->
        <mxCell id="e-ext-warn" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="extend-action" target="extend-warn" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-ext-proceed" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="extend-warn" target="extend-proceed" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-ext-end" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#28a745;strokeWidth=2;html=1;" edge="1" source="extend-proceed" target="extend-end" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Fail branch edges -->
        <mxCell id="e-fail-ok" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="fail-terminate" target="fail-ok" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-ok-yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#28a745;strokeWidth=2;html=1;fontSize=10;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="fail-ok" target="fail-ok-yes" parent="lane-hradmin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-ok-no" value="No" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#dc3545;strokeWidth=2;html=1;fontSize=10;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="fail-ok" target="fail-ok-no" parent="lane-hradmin">
