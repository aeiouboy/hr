<mxfile>
  <diagram id="ttt-11" name="11 - EC Report">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1"
                  page="1" pageScale="1" pageWidth="1800" pageHeight="1050"
                  math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Title ===== -->
        <mxCell id="title" value="TTT Process 11 — EC Report" style="text;html=1;fontSize=18;fontStyle=1;fontFamily=Helvetica;fillColor=none;strokeColor=none;fontColor=#1a1a2e;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- ===== SWIMLANE: HR Admin ===== -->
        <!-- Taller lane to accommodate the downward export branch -->
        <mxCell id="sw-hr" value="HR Admin" style="swimlane;startSize=30;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontStyle=1;fontSize=14;horizontal=1;swimlaneLine=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="1700" height="500" as="geometry" />
        </mxCell>

        <!-- ===== SWIMLANE: Manager ===== -->
        <mxCell id="sw-mgr" value="Manager" style="swimlane;startSize=30;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontStyle=1;fontSize=14;horizontal=1;swimlaneLine=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="1700" height="180" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- HR Admin lane: Row 1 — Main path (left to right)                 -->
        <!-- ================================================================ -->

        <!-- START -->
        <mxCell id="hr-start" value="START" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontStyle=1;fontSize=12;" vertex="1" parent="sw-hr">
          <mxGeometry x="40" y="70" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="hr-s1" value="1. Home → Reporting&#xa;→ Report Centre" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="200" y="67" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="hr-s2" value="2. Search by keyword&#xa;in search bar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="430" y="67" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="hr-s3" value="3. Find report → click&#xa;Action Menu → Run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="660" y="67" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="hr-s4" value="4. Runtime Filters popup&#xa;Set: BU, Company,&#xa;Cost Center, etc." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="890" y="62" width="180" height="65" as="geometry" />
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="hr-s5" value="5. Select filter values&#xa;→ Done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="1130" y="67" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- Decision: Large Report? -->
        <mxCell id="hr-d-large" value="Large&#xa;Report?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#e6a817;fontSize=12;fontFamily=Helvetica;verticalAlign=middle;" vertex="1" parent="sw-hr">
          <mxGeometry x="1360" y="57" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- HR Admin lane: Row 2 — View Results → Export decision            -->
        <!-- ================================================================ -->

        <!-- Step 6: View Results — placed in Row 2, rightward of D-Export -->
        <mxCell id="hr-s6" value="6. View Results Table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="1130" y="200" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- Decision: Export? — Row 2, left of S6 -->
        <mxCell id="hr-d-export" value="Export?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#e6a817;fontSize=12;fontFamily=Helvetica;verticalAlign=middle;" vertex="1" parent="sw-hr">
          <mxGeometry x="890" y="193" width="140" height="80" as="geometry" />
        </mxCell>

        <!-- END (no-export path) — on the same row, far left -->
        <mxCell id="hr-end1" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontStyle=1;fontSize=12;" vertex="1" parent="sw-hr">
          <mxGeometry x="700" y="203" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- HR Admin lane: Row 3 — Export branch flows DOWNWARD              -->
        <!-- Format? decision and its outputs are below the Export decision   -->
        <!-- ================================================================ -->

        <!-- Decision: Format? — below D-Export -->
        <mxCell id="hr-d-format" value="Format?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#e6a817;fontSize=12;fontFamily=Helvetica;verticalAlign=middle;" vertex="1" parent="sw-hr">
          <mxGeometry x="890" y="330" width="140" height="80" as="geometry" />
        </mxCell>

        <!-- Excel result — to the LEFT of Format? -->
        <mxCell id="hr-excel" value="Excel&#xa;(XLSX / XLS / CSV)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="680" y="335" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- PDF/Word/PPT result — to the RIGHT of Format? -->
        <mxCell id="hr-pdf" value="PDF / Word / PPT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="1090" y="335" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- Download File — below Format?, centered between Excel and PDF -->
        <mxCell id="hr-dl" value="Download File" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="860" y="435" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- END (export path) — to the LEFT of Download, same row -->
        <mxCell id="hr-end2-export" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontStyle=1;fontSize=12;" vertex="1" parent="sw-hr">
          <mxGeometry x="660" y="442" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- HR Admin lane: Large report path (right side)                    -->
        <!-- ================================================================ -->

        <!-- Auto-scheduled -->
        <mxCell id="hr-sched" value="Auto-Scheduled&#xa;(Large Report)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="1520" y="200" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- View Schedules → My Jobs -->
        <mxCell id="hr-myjobs" value="View Schedules&#xa;→ My Jobs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="1520" y="300" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- Wait: Status = Complete → Download -->
        <mxCell id="hr-waitdl" value="Wait: Status = Complete&#xa;→ Download" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="sw-hr">
          <mxGeometry x="1360" y="300" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- END (large report path) — above waitdl -->
        <mxCell id="hr-end-large" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontStyle=1;fontSize=12;" vertex="1" parent="sw-hr">
          <mxGeometry x="1380" y="200" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- Manager lane                                                      -->
        <!-- ================================================================ -->

        <mxCell id="mgr-note" value="Manager can also access EC Reports via the same path:&#xa;Home → Reporting → Report Centre → Search → Run → Set Filters → View / Export" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;fontFamily=Helvetica;align=left;spacingLeft=10;" vertex="1" parent="sw-mgr">
          <mxGeometry x="200" y="65" width="700" height="60" as="geometry" />
        </mxCell>

        <mxCell id="mgr-label" value="Same flow as HR Admin" style="text;html=1;fontSize=12;fontStyle=2;fontFamily=Helvetica;fillColor=none;strokeColor=none;fontColor=#666666;align=center;" vertex="1" parent="sw-mgr">
          <mxGeometry x="40" y="75" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- Sidebar notes (below swimlanes)                                  -->
        <!-- ================================================================ -->

        <mxCell id="note-std" value="Standard Reports:&#xa;- Position Overview&#xa;- Birthday List&#xa;- Employee Register&#xa;- Employment Changes&#xa;- Headcount &amp; FTEs&#xa;- New Hires&#xa;- Terminated Employments&#xa;- Turnover Report&#xa;- Workflow Activity Log" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;fontFamily=Helvetica;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="770" width="260" height="200" as="geometry" />
        </mxCell>

        <mxCell id="note-adv" value="Advanced Reports:&#xa;- Position Hierarchy (5 Levels)&#xa;- Employee Movements&#xa;- Workflow Activity Log&#xa;&#xa;Runtime Filters: BU, Company,&#xa;Cost Center, Legal Entity, etc." style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;fillColor=#fff3cd;strokeColor=#e6a817;fontSize=11;fontFamily=Helvetica;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="320" y="770" width="260" height="200" as="geometry" />
        </mxCell>

        <mxCell id="note-export" value="Export Formats:&#xa;Excel: XLSX, XLS, CSV&#xa;Document: PDF, Word (.docx), PPT&#xa;&#xa;Large reports auto-scheduled;&#xa;check My Jobs for status Complete,&#xa;then download." style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=11;fontFamily=Helvetica;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="770" width="300" height="200" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- EDGES — HR Admin lane                                             -->
        <!-- ================================================================ -->

        <!-- Row 1: main flow left → right -->
        <mxCell id="e-start-s1" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="hr-start" target="hr-s1" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-s1-s2" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="hr-s1" target="hr-s2" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-s2-s3" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="hr-s2" target="hr-s3" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-s3-s4" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="hr-s3" target="hr-s4" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-s4-s5" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="hr-s4" target="hr-s5" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-s5-dlarge" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;" edge="1" source="hr-s5" target="hr-d-large" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Large? NO → View Results (down from D-Large bottom → S6 top) -->
        <mxCell id="e-dlarge-no" value="NO" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#28a745;strokeWidth=1.5;html=1;fontSize=11;fontColor=#28a745;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="hr-d-large" target="hr-s6" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Large? YES → Auto-Scheduled (right side, goes down) -->
        <mxCell id="e-dlarge-yes" value="YES" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#4a90b8;strokeWidth=1.5;html=1;fontSize=11;fontColor=#4a90b8;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="hr-d-large" target="hr-sched" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- View Results → Export? (leftward on Row 2) -->
        <mxCell id="e-s6-export" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="hr-s6" target="hr-d-export" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Export? NO → END (leftward on Row 2) -->
        <mxCell id="e-export-no" value="NO" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#dc3545;strokeWidth=1.5;html=1;fontSize=11;fontColor=#dc3545;fontStyle=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="hr-d-export" target="hr-end1" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Export? YES → Format? (DOWNWARD — exit bottom of D-Export, enter top of D-Format) -->
        <mxCell id="e-export-yes" value="YES" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;fontSize=11;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="hr-d-export" target="hr-d-format" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Format? → Excel (exit left side of Format? → enter right side of Excel) -->
        <mxCell id="e-fmt-excel" value="Excel" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#28a745;strokeWidth=1.5;html=1;fontSize=11;fontColor=#28a745;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="hr-d-format" target="hr-excel" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Format? → PDF/Word/PPT (exit right side of Format? → enter left side of PDF) -->
        <mxCell id="e-fmt-pdf" value="PDF/Word/PPT" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#28a745;strokeWidth=1.5;html=1;fontSize=11;fontColor=#28a745;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="hr-d-format" target="hr-pdf" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Excel → Download (exit bottom of Excel → enter top-left of Download with waypoint) -->
        <mxCell id="e-excel-dl" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="hr-excel" target="hr-dl" parent="sw-hr">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="755" y="467" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- PDF → Download (exit bottom of PDF → enter top-right of Download with waypoint) -->
        <mxCell id="e-pdf-dl" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="hr-pdf" target="hr-dl" parent="sw-hr">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1165" y="467" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Download → END (leftward — exit left of Download → enter right of END) -->
        <mxCell id="e-dl-end" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="hr-dl" target="hr-end2-export" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Large report path: sched → myjobs → waitdl → end-large -->
        <mxCell id="e-sched-jobs" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="hr-sched" target="hr-myjobs" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-jobs-wait" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="hr-myjobs" target="hr-waitdl" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-wait-end-large" style="edgeStyle=orthogonalEdgeStyle;curved=1;endArrow=classic;strokeColor=#666666;strokeWidth=1.5;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="hr-waitdl" target="hr-end-large" parent="sw-hr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
