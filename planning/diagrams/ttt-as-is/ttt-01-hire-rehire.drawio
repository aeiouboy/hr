        <!-- Decision: Rehire? -->
        <mxCell id="dup-dec" value="Rehire?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#e6a817;fontSize=12;" vertex="1" parent="lane-hradmin">
          <mxGeometry x="450" y="55" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- Rehire branch: Duplicate Check -->
        <mxCell id="dup-check" value="Duplicate Check&#xa;(DOB + National ID)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=12;" vertex="1" parent="lane-hradmin">
          <mxGeometry x="650" y="60" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Match Found? -->
