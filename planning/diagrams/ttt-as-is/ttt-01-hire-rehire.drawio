        <mxCell id="end-normal" value="End" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="lane-hradmin">
          <mxGeometry x="1650" y="245" width="60" height="50" as="geometry" />
