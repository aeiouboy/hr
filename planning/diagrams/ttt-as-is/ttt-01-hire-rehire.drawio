<mxfile host="app.diagrams.net" modified="2026-04-10" version="21.0.0">
  <diagram id="ttt01-hire-rehire" name="01 - Hire &amp; Rehire">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Process 01 — Hire &amp; Rehire (SAP SuccessFactors EC Core As-Is, 2018)" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="40" y="16" width="1720" height="30" as="geometry" />
        </mxCell>

        <!-- Single swimlane: HR Admin -->
        <mxCell id="lane-hradmin" value="HR Admin" style="swimlane;startSize=40;horizontal=0;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1740" height="1300" as="geometry" />
        </mxCell>

        <!-- ===== SECTION A: Main Hire Flow ===== -->
        <mxCell id="sec-a-label" value="Main Flow" style="text;html=1;fontSize=11;fontStyle=3;align=left;fillColor=none;strokeColor=none;fontColor=#aaaaaa;" vertex="1" parent="lane-hradmin">
