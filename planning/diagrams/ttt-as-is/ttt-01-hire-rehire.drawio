          <mxGeometry x="60" y="630" width="1620" height="10" as="geometry" />
        </mxCell>

        <!-- ===== SECTION C: Business Rules Note ===== -->
        <mxCell id="note-rules" value="Business Rules:&#xa;- Employee ID auto-generated (never manual input)&#xa;- Probation End Date = Hire Date + 119 days (system-calculated)&#xa;- Retirement Date = DOB + 60 years&#xa;- Rehire: Original Start Date preserved; Seniority Start Date reset to rehire date&#xa;- Event Reasons: New Hire / Replacement / Temporary Assignment / HIRE Incorrect Entry / HIRE Corrected Entry&#xa;- Rehire Reasons: Rehiring LT 1 year / Rehiring GE 1 year" style="text;html=1;fontSize=10;align=left;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontColor=#333333;rounded=1;" vertex="1" parent="lane-hradmin">
          <mxGeometry x="60" y="650" width="700" height="120" as="geometry" />
        </mxCell>

        <!-- ===== EDGES ===== -->

