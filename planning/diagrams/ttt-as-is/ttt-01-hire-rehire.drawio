          <mxGeometry x="1100" y="55" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- ===== Row 2: Steps 1-5 (main hire steps) ===== -->
        <mxCell id="step1" value="Step 1: Identity&#xa;— Hire Date&#xa;— Company&#xa;— Event Reason&#xa;— Name EN&#xa;— Date of Birth&#xa;— National ID + attachment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=11;align=left;" vertex="1" parent="lane-hradmin">
          <mxGeometry x="200" y="220" width="190" height="140" as="geometry" />
        </mxCell>

        <mxCell id="step2" value="Step 2: Personal Info&#xa;— Name TH&#xa;— Gender&#xa;— Marital Status&#xa;— Nationality / Race&#xa;— Military Status&#xa;— Contact Info&#xa;— Address (cascade)&#xa;— Emergency Contact&#xa;— Dependents" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=11;align=left;" vertex="1" parent="lane-hradmin">
          <mxGeometry x="460" y="210" width="190" height="160" as="geometry" />
        </mxCell>

        <mxCell id="step3" value="Step 3: Job Information&#xa;— Position (auto-fills)&#xa;— Employee Group (manual)&#xa;— Employee Subgroup (manual)&#xa;— Contract Type (manual)&#xa;— Contract End Date&#xa;— Probation End (Hire+119d)&#xa;— Corporate Title" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=11;align=left;" vertex="1" parent="lane-hradmin">
          <mxGeometry x="720" y="210" width="200" height="160" as="geometry" />
        </mxCell>

        <mxCell id="step4" value="Step 4: Job Relationship&#xa;— Matrix Manager&#xa;— Custom Manager (LMS)&#xa;— Work Permit Info" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=11;align=left;" vertex="1" parent="lane-hradmin">
          <mxGeometry x="990" y="220" width="190" height="110" as="geometry" />
        </mxCell>

        <mxCell id="step5" value="Step 5: Compensation&#xa;— Pay Group&#xa;— Pay Component / Amount&#xa;— Currency / Frequency&#xa;— Payment Method&#xa;— Bank details" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90b8;fontSize=11;align=left;" vertex="1" parent="lane-hradmin">
