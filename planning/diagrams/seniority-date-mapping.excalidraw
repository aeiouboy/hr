    {
      "type": "text", "id": "brd86_text", "x": 60, "y": 315, "width": 260, "height": 150,
      "text": "BRD #86 — Year of Service\nflow-08 Employment Info\n\nCRC: นับอายุงาน\n  Re-Hire → New Code\n  Default Hire → Seniority Date\n  (override ได้)\nCPN: เหมือน CRC\nNON-CNEXT: Dummy Assignment\n  → Transfer → นับต่อเนื่อง",
      "originalText": "BRD #86 — Year of Service\nflow-08 Employment Info\n\nCRC: นับอายุงาน\n  Re-Hire → New Code\n  Default Hire → Seniority Date\n  (override ได้)\nCPN: เหมือน CRC\nNON-CNEXT: Dummy Assignment\n  → Transfer → นับต่อเนื่อง",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#ffffff", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "seed": 102, "version": 1, "versionNonce": 103,
