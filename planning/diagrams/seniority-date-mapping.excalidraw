    {
      "type": "text", "id": "brd87_90_text", "x": 60, "y": 505, "width": 260, "height": 170,
      "text": "BRDs #87-92 — Year In *\nflow-08 Employment Info\n\n#87 Year In Store Branch\n  CPN: branch size rules\n  Small→Small = ไม่ reset\n#88 Year In Position ⚠\n  Change Position/Reorg = ต่อ\n  Other events = reset\n  + Override field\n#89 Year In Job (reset on change)\n#90 Year In JG (reset on change)\n#91 Year In PG\n#92 Year In BU + Field Others",
      "originalText": "BRDs #87-92 — Year In *\nflow-08 Employment Info\n\n#87 Year In Store Branch\n  CPN: branch size rules\n  Small→Small = ไม่ reset\n#88 Year In Position ⚠\n  Change Position/Reorg = ต่อ\n  Other events = reset\n  + Override field\n#89 Year In Job (reset on change)\n#90 Year In JG (reset on change)\n#91 Year In PG\n#92 Year In BU + Field Others",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#6d28d9", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
