    {
      "type": "text", "id": "sub_code_text", "x": 60, "y": 960, "width": 530, "height": 110,
      "text": "agent.subscribe({\n  onTextMessageContentEvent(e) { appendText(e.delta) },\n  onToolCallStartEvent(e)     { showToolCall(e.toolCallName) },\n  onStateSnapshotEvent(e)      { setState(e.snapshot) },\n  onStateDeltaEvent(e)         { applyPatch(state, e.delta) },\n  onRunFinishedEvent(e)        { resolve(e.result) },\n  onEvent(e)                   { /* catch-all */ }\n})",
      "originalText": "agent.subscribe({\n  onTextMessageContentEvent(e) { appendText(e.delta) },\n  onToolCallStartEvent(e)     { showToolCall(e.toolCallName) },\n  onStateSnapshotEvent(e)      { setState(e.snapshot) },\n  onStateDeltaEvent(e)         { applyPatch(state, e.delta) },\n  onRunFinishedEvent(e)        { resolve(e.result) },\n  onEvent(e)                   { /* catch-all */ }\n})",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "seed": 312, "version": 1, "versionNonce": 313,
      "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false,
