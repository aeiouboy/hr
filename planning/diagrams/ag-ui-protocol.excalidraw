    {
      "type": "text", "id": "seq2_text", "x": 60, "y": 758, "width": 1280, "height": 55,
      "text": "data: {\"type\":\"TOOL_CALL_START\", \"toolCallId\":\"tc1\", \"toolCallName\":\"search_db\"}\ndata: {\"type\":\"TOOL_CALL_ARGS\", \"toolCallId\":\"tc1\", \"delta\":\"{\\\"query\\\":\"}\ndata: {\"type\":\"TOOL_CALL_ARGS\", \"toolCallId\":\"tc1\", \"delta\":\"\\\"python\\\"}\"}\ndata: {\"type\":\"TOOL_CALL_END\", \"toolCallId\":\"tc1\"}\ndata: {\"type\":\"TOOL_CALL_RESULT\", \"toolCallId\":\"tc1\", \"content\":\"[{...results}]\", \"role\":\"tool\"}",
