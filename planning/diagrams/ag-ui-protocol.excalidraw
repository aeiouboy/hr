    {
      "type": "text", "id": "server_code_text", "x": 660, "y": 960, "width": 680, "height": 110,
      "text": "@app.post(\"/\")\nasync def agent_endpoint(input: RunAgentInput, request: Request):\n    encoder = EventEncoder(accept=request.headers.get(\"accept\"))\n    async def event_generator():\n        yield encoder.encode(RunStartedEvent(thread_id=input.thread_id, run_id=input.run_id))\n        async for chunk in llm_stream:\n            yield encoder.encode(TextMessageChunkEvent(message_id=\"m1\", delta=chunk.text))\n        yield encoder.encode(RunFinishedEvent(thread_id=input.thread_id, run_id=input.run_id))\n    return StreamingResponse(event_generator(), media_type=encoder.get_content_type())",
      "originalText": "@app.post(\"/\")\nasync def agent_endpoint(input: RunAgentInput, request: Request):\n    encoder = EventEncoder(accept=request.headers.get(\"accept\"))\n    async def event_generator():\n        yield encoder.encode(RunStartedEvent(thread_id=input.thread_id, run_id=input.run_id))\n        async for chunk in llm_stream:\n            yield encoder.encode(TextMessageChunkEvent(message_id=\"m1\", delta=chunk.text))\n        yield encoder.encode(RunFinishedEvent(thread_id=input.thread_id, run_id=input.run_id))\n    return StreamingResponse(event_generator(), media_type=encoder.get_content_type())",
      "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "seed": 322, "version": 1, "versionNonce": 323,
      "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false,
      "containerId": "server_code", "lineHeight": 1.25
    },
