    {
      "type": "text",
      "id": "contract_steps",
      "x": 55,
      "y": 1667,
      "width": 450,
      "height": 180,
      "text": "Contract Renewal:\n  1. Verify current Contract End Date on Employment Info\n  2. Actions → Change Job and Comp → Job Info\n  3. Event = Data Change, Reason = Extend Contract\n  4. Update Contract End Date → Save (system validates)\n\nSuspension:\n  1. Employment Info → Job Info → Insert New Record (NOT Take Action)\n  2. Event = Suspension, Reason = Suspension\n  3. Save → Status changes to Suspended\n  Return: Insert New Record → Event = Return from Suspension → Active",
      "originalText": "Contract Renewal:\n  1. Verify current Contract End Date on Employment Info\n  2. Actions → Change Job and Comp → Job Info\n  3. Event = Data Change, Reason = Extend Contract\n  4. Update Contract End Date → Save (system validates)\n\nSuspension:\n  1. Employment Info → Job Info → Insert New Record (NOT Take Action)\n  2. Event = Suspension, Reason = Suspension\n  3. Save → Status changes to Suspended\n  Return: Insert New Record → Event = Return from Suspension → Active",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#475569",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
