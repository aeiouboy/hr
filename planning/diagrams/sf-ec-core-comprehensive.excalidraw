    {
      "type": "text",
      "id": "contract_rules",
      "x": 520,
      "y": 1630,
      "width": 480,
      "height": 190,
      "text": "Contract: System warns if Contract End Date not changed — must click Proceed\nSuspension: Uses DIFFERENT path from all other processes (Insert New Record)\nSuspension changes Employee Status: Active → Suspended → Active (on return)\nChange Employee Type: same UI but Event = Change Employee Type\n  Sub-types: Type Change, Extend Retirement, Change in Time, Change in Pay",
      "originalText": "Contract: System warns if Contract End Date not changed — must click Proceed\nSuspension: Uses DIFFERENT path from all other processes (Insert New Record)\nSuspension changes Employee Status: Active → Suspended → Active (on return)\nChange Employee Type: same UI but Event = Change Employee Type\n  Sub-types: Type Change, Extend Retirement, Change in Time, Change in Pay",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#475569",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
