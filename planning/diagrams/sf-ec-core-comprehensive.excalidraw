    {
      "type": "text",
      "id": "hire_rules",
      "x": 520,
      "y": 130,
      "width": 480,
      "height": 190,
      "text": "Employee Groups: A(Permanent), W(Expat Out), C(Expat In), D(Retirement), E(Temp), F(DVT), G(Intern), H(Contingent)\n12 scenarios: 7 Hiring + 3 Rehiring + Pending Recruits + Correct Hire Date\nPosition selection auto-populates all org hierarchy fields\nEmployee ID = system auto-generated",
      "originalText": "Employee Groups: A(Permanent), W(Expat Out), C(Expat In), D(Retirement), E(Temp), F(DVT), G(Intern), H(Contingent)\n12 scenarios: 7 Hiring + 3 Rehiring + Pending Recruits + Correct Hire Date\nPosition selection auto-populates all org hierarchy fields\nEmployee ID = system auto-generated",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#475569",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
