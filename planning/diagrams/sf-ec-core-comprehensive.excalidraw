    {
      "type": "text",
      "id": "movement_rules",
      "x": 520,
      "y": 1030,
      "width": 480,
      "height": 190,
      "text": "Transfer within company (no SSO change) = Job Info only\nTransfer within company (SSO change) = Job Info + Compensation update required\nTransfer across company = separate Event Reason, different flow\nPromotion/Demotion = same flow as Transfer with different Event\nActing Assignment: Actions → Add Concurrent Employment (separate path)\n  Acting uses Pay Group = 99 (non-payroll relevant)\n  End Acting: Terminate selected assignment (not main employment)",
      "originalText": "Transfer within company (no SSO change) = Job Info only\nTransfer within company (SSO change) = Job Info + Compensation update required\nTransfer across company = separate Event Reason, different flow\nPromotion/Demotion = same flow as Transfer with different Event\nActing Assignment: Actions → Add Concurrent Employment (separate path)\n  Acting uses Pay Group = 99 (non-payroll relevant)\n  End Acting: Terminate selected assignment (not main employment)",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
