    {
      "type": "text",
      "id": "p05_fr_t",
      "x": 60,
      "y": 6247,
      "width": 1080,
      "height": 104,
      "text": "FR-42: Resign: TERM_RESIGN (Voluntary) → no workflow required\nFR-43: Retirement: TERM_RETRIE → Retirement Date = DOB + 60 years (CPN: 1 Jan Y+1, Others: 1 Mar Y+1)\nFR-44: Dismissal: TERM_DISMIS (Involuntary) → MANDATORY workflow (Manager ↔ HRBP approval)\nFR-45: No Show: Purge Employee ID from system\nFR-46: Key fields: Resigned Date, Last Date Worked, OK to Rehire (Yes/No = blacklist)\nFR-47: Transfer Direct Subordinates: 3 options available before termination completes\nFR-48: Multi-position rule: Must select 'All Employments' to truly terminate from company\nFR-49: End of Contract: automatic when contract end date reached",
      "originalText": "FR-42: Resign: TERM_RESIGN (Voluntary) → no workflow required\nFR-43: Retirement: TERM_RETRIE → Retirement Date = DOB + 60 years (CPN: 1 Jan Y+1, Others: 1 Mar Y+1)\nFR-44: Dismissal: TERM_DISMIS (Involuntary) → MANDATORY workflow (Manager ↔ HRBP approval)\nFR-45: No Show: Purge Employee ID from system\nFR-46: Key fields: Resigned Date, Last Date Worked, OK to Rehire (Yes/No = blacklist)\nFR-47: Transfer Direct Subordinates: 3 options available before termination completes\nFR-48: Multi-position rule: Must select 'All Employments' to truly terminate from company\nFR-49: End of Contract: automatic when contract end date reached",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
