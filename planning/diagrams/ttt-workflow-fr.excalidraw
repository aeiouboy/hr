    {
      "type": "text",
      "id": "bw03b_rules_t",
      "x": 60,
      "y": 3799,
      "width": 1080,
      "height": 52,
      "text": "BR-22: Event Reasons: PRCHG_MERIT, PRCHG_ADJPOS, PRCHG_SALCUT, PRCHG_SALADJ, PRCHG_PRM\nBR-23: Mass Upload = 2 files: CompInfoImportTemplate.csv + PayComponentRecurringImportTemplate.csv\nBR-24: Mass Upload settings: Purge = Incremental, Date = dd/MM/yyyy, Encoding = UTF-8\nBR-25: Future-dated record blocks backdated insert → ต้องลบ future record ก่อน",
      "originalText": "BR-22: Event Reasons: PRCHG_MERIT, PRCHG_ADJPOS, PRCHG_SALCUT, PRCHG_SALADJ, PRCHG_PRM\nBR-23: Mass Upload = 2 files: CompInfoImportTemplate.csv + PayComponentRecurringImportTemplate.csv\nBR-24: Mass Upload settings: Purge = Incremental, Date = dd/MM/yyyy, Encoding = UTF-8\nBR-25: Future-dated record blocks backdated insert → ต้องลบ future record ก่อน",
      "fontSize": 9,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
