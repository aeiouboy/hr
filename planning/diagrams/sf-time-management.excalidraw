    {
      "type": "text",
      "id": "ee_list",
      "x": 55,
      "y": 148,
      "width": 530,
      "height": 180,
      "text": "EE-01  Navigation — WFS Home via SuccessFactors SSO\nEE-02  Web Clock — Clock In/Out at workstation\nEE-03  Mobile Clock — Clock In/Out with GPS location\nEE-04  My Time Off — Request leave (balance check + conflict detect)\nEE-05  My Timesheet (OT) — Submit overtime hours for approval\nEE-06  Amendment Timesheet — Correct past time entries\nEE-07  My Calendar — View personal schedule + approved leave",
      "originalText": "EE-01  Navigation — WFS Home via SuccessFactors SSO\nEE-02  Web Clock — Clock In/Out at workstation\nEE-03  Mobile Clock — Clock In/Out with GPS location\nEE-04  My Time Off — Request leave (balance check + conflict detect)\nEE-05  My Timesheet (OT) — Submit overtime hours for approval\nEE-06  Amendment Timesheet — Correct past time entries\nEE-07  My Calendar — View personal schedule + approved leave",
      "fontSize": 12,
      "fontFamily": 2,
