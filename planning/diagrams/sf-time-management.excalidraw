    {
      "type": "text",
      "id": "mgr_list",
      "x": 635,
      "y": 148,
      "width": 545,
      "height": 180,
      "text": "MGR-01  Navigation — Manager dashboard\nMGR-02  Assign Schedules — Set work schedules per employee\nMGR-03  Edit Employee Time — Correct individual records\nMGR-04  Group Schedule — Bulk schedule assignment\nMGR-05  Employee Calendar — View one employee's calendar\nMGR-06  Group Calendar — View team calendar (coverage check)\nMGR-07  Edit Time For Group — Bulk time corrections\nMGR-09  Approve Timesheet (OT, LIA) — Approve/reject OT requests\nMGR-10  Approve Amend Timesheet — Approve past corrections\nMGR-11  Manage Delegations — Delegate approval authority\nMGR-12  Mobile Function — All above via mobile app",
      "originalText": "MGR-01  Navigation — Manager dashboard\nMGR-02  Assign Schedules — Set work schedules per employee\nMGR-03  Edit Employee Time — Correct individual records\nMGR-04  Group Schedule — Bulk schedule assignment\nMGR-05  Employee Calendar — View one employee's calendar\nMGR-06  Group Calendar — View team calendar (coverage check)\nMGR-07  Edit Time For Group — Bulk time corrections\nMGR-09  Approve Timesheet (OT, LIA) — Approve/reject OT requests\nMGR-10  Approve Amend Timesheet — Approve past corrections\nMGR-11  Manage Delegations — Delegate approval authority\nMGR-12  Mobile Function — All above via mobile app",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
